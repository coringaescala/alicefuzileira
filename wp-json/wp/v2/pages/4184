or: #FFFFFF; \/* Cor do texto (Branco) *\/\r\n    font-size: 32px; \/* Tamanho da fonte *\/\r\n    line-height: 1;\r\n    text-transform: uppercase;\r\n    letter-spacing: 1px;\r\n}\r\n\r\n\/* Unidade de tempo (ex: 22 Horas) *\/\r\n.timer-unit {\r\n    display: flex;\r\n    gap: 6px; \/* Espa\u00e7o entre o n\u00famero e a palavra *\/\r\n    white-space: nowrap;\r\n}\r\n\r\n\/* Responsividade para celular *\/\r\n@media (max-width: 480px) {\r\n    #daily-timer-simple {\r\n        font-size: 24px; \/* Reduz um pouco no celular *\/\r\n        gap: 10px;\r\n    }\r\n}\r\n<\/style>\r\n\r\n<div id=\"daily-timer-simple\">\r\n    <!-- Horas -->\r\n    <div class=\"timer-unit\">\r\n        <span id=\"simple-hours\">00<\/span> <span>Horas<\/span>\r\n    <\/div>\r\n\r\n    <!-- Minutos -->\r\n    <div class=\"timer-unit\">\r\n        <span id=\"simple-minutes\">00<\/span> <span>Minutos<\/span>\r\n    <\/div>\r\n\r\n    <!-- Segundos -->\r\n    <div class=\"timer-unit\">\r\n        <span id=\"simple-seconds\">00<\/span> <span>Segundos<\/span>\r\n    <\/div>\r\n<\/div>\r\n\r\n<script>\r\n(function() {\r\n    function runSimpleDailyTimer() {\r\n        const now = new Date();\r\n        const endOfDay = new Date();\r\n\r\n        \/\/ Define o alvo para 23:59:59 de HOJE\r\n        endOfDay.setHours(23, 59, 59, 999);\r\n\r\n        \/\/ Calcula a diferen\u00e7a\r\n        let distance = endOfDay - now;\r\n\r\n        \/\/ Se virou o dia (ficou negativo), zera\r\n        if (distance < 0) {\r\n            distance = 0;\r\n        }\r\n\r\n        \/\/ C\u00e1lculos matem\u00e1ticos (Sem dias)\r\n        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) \/ (1000 * 60 * 60));\r\n        const minutes = Math.floor((distance % (1000 * 60 * 60)) \/ (1000 * 60));\r\n        const seconds = Math.floor((distance % (1000 * 60)) \/ 1000);\r\n\r\n        \/\/ Formata com zero \u00e0 esquerda (ex: 09)\r\n        const format = (num) => num < 10 ? '0' + num : num;\r\n\r\n        \/\/ Atualiza o HTML\r\n        document.getElementById('simple-hours').innerText = format(hours);\r\n        document.getElementById('simple-minutes').innerText = format(minutes);\r\n        document.getElementById('simple-seconds').innerText = format(seconds);\r\n    }\r\n\r\n    \/\/ Atualiza a cada 1 segundo\r\n    setInterval(runSimpleDailyTimer, 1000);\r\n    \r\n    \/\/ Roda imediatamente\r\n    runSimpleDailyTimer();\r\n})();\r\n<\/script>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-566c3de e-flex e-con-boxed e-con e-parent\" data-id=\"566c3de\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;,&quot;_ha_eqh_enable&quot;:false}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-f2dd753 e-con-full e-flex e-con e-child\" data-id=\"f2dd753\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\">\n\t\t\t\t<div class=\"elementor-element elementor-element-ee155c2 elementor-widget elementor-widget-image\" data-id=\"ee155c2\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img decoding=\"async\" width=\"263\" height=\"125\" src=\"https:\/\/alicefuzileira.com.br\/wp-content\/uploads\/2024\/06\/fora-do-sistema-1.png\" class=\"attachment-full size-full wp-image-1224\" alt=\"\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-676ff2a elementor-widget elementor-widget-heading\" data-id=\"676ff2a\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Esteja preparado para enfr