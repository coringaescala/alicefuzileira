idget elementor-widget-heading\" data-id=\"f82205e\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">O protocolo FDS \u00c9 UM <span class=\"destaque\">PROGRAMA DE FORMA\u00c7\u00c3O DE 12 MESES<\/span>, DIVIDIDO EM <span class=\"destaque\">3 FASES<\/span> CLARAS.<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-0e5f2d7 e-con-full e-flex e-con e-child\" data-id=\"0e5f2d7\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\">\n\t\t\t\t<div class=\"elementor-element elementor-element-823b74b elementor-widget elementor-widget-html\" data-id=\"823b74b\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"html.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<style>\r\n\r\n.fds-timeline-wrapper {\r\n    background-color: #000000;\r\n    color: #ffffff;\r\n    font-family: 'Sora', sans-serif;\r\n    padding: 60px 0;\r\n    width: 100%;\r\n    box-sizing: border-box;\r\n    overflow-x: hidden;\r\n}\r\n\r\n.fds-phases-grid {\r\n    display: grid;\r\n    grid-template-columns: 1fr 1fr 1fr;\r\n    gap: 0;\r\n    max-width: 1400px;\r\n    margin: 0 auto;\r\n    width: 100%;\r\n    \/* Garante que as colunas estiquem igualmente *\/\r\n    align-items: stretch; \r\n}\r\n\r\n\/* =========================================\r\n   COLUNA DA FASE\r\n   ========================================= *\/\r\n.fds-phase-col {\r\n    position: relative;\r\n    display: flex;\r\n    flex-direction: column;\r\n    padding-top: 0; \r\n}\r\n\r\n\/* LINHA VERTICAL (GUIA) *\/\r\n.fds-vertical-guide {\r\n    position: absolute;\r\n    left: 0;\r\n    top: 0; \r\n    height: 100px; \/* Altura fixa ajustada para encontrar a linha horizontal *\/\r\n    width: 1px;\r\n    background: linear-gradient(